#include "Resource.h"

IDR_MAINFRAME MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&Open Model...\tCtrl+O",  ID_FILE_OPEN
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                   ID_APP_EXIT
    END
    POPUP "&View"
    BEGIN
        MENUITEM "&Wireframe",              ID_VIEW_WIREFRAME
        MENUITEM "&Flat Shading",           ID_VIEW_FLAT
        MENUITEM "&Gouraud Shading",        ID_VIEW_GOURAUD
        MENUITEM "&Texture Mapping",        ID_VIEW_TEXTURE
    END
    POPUP "&Animation"
    BEGIN
        MENUITEM "&Start\tF5",              ID_ANIMATION_START
        MENUITEM "&Stop\tF6",               ID_ANIMATION_STOP
    END
END

IDR_MAINFRAME ACCELERATORS
BEGIN
    "O",            ID_FILE_OPEN,           VIRTKEY, CONTROL, NOINVERT
    VK_F5,          ID_ANIMATION_START,     VIRTKEY, NOINVERT
    VK_F6,          ID_ANIMATION_STOP,      VIRTKEY, NOINVERT
END

IDD_ABOUTBOX DIALOGEX 0, 0, 250, 100
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION
CAPTION "About Realistic Renderer"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "Realistic 3D Renderer v2.0", IDC_STATIC, 40, 16, 180, 12
    LTEXT           "MFC Software Rendering Pipeline", IDC_STATIC, 40, 32, 180, 12
    LTEXT           "Wireframe | Flat | Gouraud | Texture", IDC_STATIC, 40, 48, 180, 12
    DEFPUSHBUTTON   "OK", IDOK, 100, 70, 50, 20
END

STRINGTABLE
BEGIN
    AFX_IDS_APP_TITLE       "Realistic Renderer"
    AFX_IDS_IDLEMESSAGE     "Ready"
END

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 2,0,0,0
 PRODUCTVERSION 2,0,0,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0
 FILEOS VOS__WINDOWS32
 FILETYPE VFT_APP
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904E4"
        BEGIN
            VALUE "FileDescription", "Realistic 3D Renderer"
            VALUE "FileVersion", "2.0.0.0"
            VALUE "ProductName", "Realistic Renderer"
            VALUE "ProductVersion", "2.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1252
    END
END
